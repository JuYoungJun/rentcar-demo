# ══════════════════════════════
# 해태렌트카 — Cafe24/Apache 설정
# ══════════════════════════════

# UTF-8 기본 (한글 컨텐츠)
AddDefaultCharset UTF-8

# WebP MIME (구형 Apache 대비)
<IfModule mod_mime.c>
  AddType image/webp .webp
</IfModule>

# ── GZIP 압축 (mod_deflate) ────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml
  AddOutputFilterByType DEFLATE text/css text/javascript application/javascript application/x-javascript
  AddOutputFilterByType DEFLATE application/json application/xml application/rss+xml
  AddOutputFilterByType DEFLATE image/svg+xml font/woff font/woff2
</IfModule>

# ── 캐시 헤더 (mod_expires) ────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On

  # 이미지/폰트 — 1개월
  ExpiresByType image/webp                "access plus 1 month"
  ExpiresByType image/jpeg                "access plus 1 month"
  ExpiresByType image/png                 "access plus 1 month"
  ExpiresByType image/svg+xml             "access plus 1 month"
  ExpiresByType image/x-icon              "access plus 1 month"
  ExpiresByType font/woff                 "access plus 1 month"
  ExpiresByType font/woff2                "access plus 1 month"

  # CSS/JS — 1주 (배포 후 곧바로 반영되도록 비교적 짧게)
  ExpiresByType text/css                  "access plus 1 week"
  ExpiresByType application/javascript    "access plus 1 week"

  # HTML — 캐시 안 함 (항상 최신)
  ExpiresByType text/html                 "access plus 0 seconds"
</IfModule>

# ── 보안 헤더 ──────────────────────────────────────
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"

  # HTML은 캐시 안 함
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>

# ── 디렉토리 인덱싱 차단 ───────────────────────────
Options -Indexes

# ── .htaccess / 환경설정 파일 보호 ─────────────────
<FilesMatch "^\.(htaccess|htpasswd|env|git)">
  Require all denied
</FilesMatch>

# ── 관리자 폴더 — 추후 백엔드 인증 적용 시 활성화 ──
# 현재(데모): 클라이언트 측 JS 게이트만 있음.
# 운영 배포 시 다음 중 하나로 교체:
#  (1) Basic Auth (.htpasswd):
#      <Directory "/path/to/admin">
#        AuthType Basic
#        AuthName "Admin"
#        AuthUserFile /절대경로/.htpasswd
#        Require valid-user
#      </Directory>
#  (2) PHP 세션 + DB 인증으로 admin/login.php 변경
