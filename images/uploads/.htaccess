# ══════════════════════════════════════════════════════════
# 업로드 폴더 — PHP/스크립트 실행 차단 (Defense-in-depth)
# ══════════════════════════════════════════════════════════

# 이미지만 직접 서빙 허용
<FilesMatch "\.(jpg|jpeg|png|webp|avif|gif|svg)$">
  Require all granted
</FilesMatch>

# .php / .phtml / .pl / .py / .sh / .cgi 등 실행 가능 파일 일괄 차단
<FilesMatch "\.(php|phtml|phps|pl|py|sh|cgi|jsp|asp|aspx|exe|bat)$">
  Require all denied
</FilesMatch>

# 디렉토리 인덱싱 차단
Options -Indexes -ExecCGI

# PHP 핸들러 비활성 (이중 안전장치)
<IfModule mod_php.c>
  php_flag engine off
</IfModule>
<IfModule mod_php7.c>
  php_flag engine off
</IfModule>
<IfModule mod_php8.c>
  php_flag engine off
</IfModule>

# .htaccess 자체 차단
<FilesMatch "^\.">
  Require all denied
</FilesMatch>
