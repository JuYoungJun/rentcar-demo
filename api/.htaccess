# ══════════════════════════════════════════════════════════
# API 폴더 — Apache 보안 정책 (카페24)
# ══════════════════════════════════════════════════════════

# 디렉토리 인덱스 차단
Options -Indexes

# 민감 파일 차단 — _config.php / _helpers.php / _db.php 등 인클루드 전용 파일 직접 접근 금지
<FilesMatch "^_">
  Require all denied
</FilesMatch>

# 데이터 폴더 보호 + Authorization 헤더 PHP 전달
# Apache 가 기본적으로 Authorization 헤더를 PHP $_SERVER 에 안 넘김.
# Bearer 토큰 인증을 위해 HTTP_AUTHORIZATION 환경변수로 명시 전달.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule ^data/ - [F,L]
  RewriteCond %{HTTP:Authorization} ^(.+)$
  RewriteRule .* - [E=HTTP_AUTHORIZATION:%1]
</IfModule>
SetEnvIf Authorization "(.*)" HTTP_AUTHORIZATION=$1

# 보안 헤더
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "no-referrer"
  Header set Cache-Control "no-store, no-cache, must-revalidate"

  # CORS 는 PHP 측에서 제어
</IfModule>

# PHP 에러 메시지 외부 노출 차단 (운영)
<IfModule mod_php.c>
  php_flag display_errors off
  php_flag log_errors on
</IfModule>
